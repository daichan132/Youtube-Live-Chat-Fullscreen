{
  "name": "youtube-live-chat-fullscreen",
  "private": true,
  "version": "2.3.7",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "submit:chrome:v2": "node scripts/cws-v2-submit.mjs",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "format": "biome format --write ./entrypoints/** ./shared/**",
    "lint": "biome check --write ./entrypoints/** ./shared/** && tsc --noEmit",
    "test:unit": "vitest run",
    "prepare": "lefthook install",
    "e2e": "playwright test --project=e2e",
    "e2e:archive": "playwright test --project=e2e --grep @archive",
    "e2e:live": "playwright test --project=e2e --grep @live",
    "screenshots": "playwright test --project=screenshots --workers=1"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "re-resizable": "^6.11.2",
    "react": "19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.4",
    "react-i18next": "^17.0.2",
    "redux-persist-webextension-storage": "^1.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@playwright/test": "1.59.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/redux-persist-webextension-storage": "1.0.3",
    "@wxt-dev/module-react": "1.2.2",
    "@wxt-dev/unocss": "1.0.1",
    "jsdom": "29.0.2",
    "lefthook": "2.1.5",
    "typescript": "6.0.2",
    "unocss": "66.6.8",
    "vite": "8.0.7",
    "vitest": "4.1.3",
    "wxt": "0.20.20"
  },
  "resolutions": {
    "@isaacs/brace-expansion": "5.0.1",
    "brace-expansion": "5.0.5",
    "glob": "13.0.1",
    "lodash": "4.17.23",
    "lodash-es": "4.17.23",
    "node-forge": "1.3.3",
    "tar": "7.5.7",
    "vite": "8.0.7"
  },
  "packageManager": "yarn@4.13.0",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions"
  ]
}
